# Departarr — environment overrides
# All of these are OPTIONAL. Secrets are auto-generated on first boot and stored
# in ./data/config.json. API keys can be pasted in Settings → Data Sources after
# logging in — no .env file required for a standard self-hosted deployment.

# --- Database ---
# Defaults to file:/data/departarr.db in the container (mounted at ./data).
# DATABASE_URL=file:/data/departarr.db

# --- Auth ---
# Auto-generated on first boot. Override only if you want a fixed secret.
# JWT_SECRET=

# --- FlightAware AeroAPI ---
# Preferred path: Settings → Data Sources in the UI.
# https://www.flightaware.com/commercial/aeroapi
# FLIGHTAWARE_API_KEY=

# --- Web Push (VAPID) ---
# Auto-generated on first boot. Override only if migrating existing subscriptions.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# Contact email for push (can also be set in Settings → Data Sources):
# VAPID_SUBJECT=mailto:you@example.com

# --- Google Calendar OAuth ---
# Preferred path: Settings → Data Sources in the UI.
# https://console.cloud.google.com
# Redirect URI (auto-derived from request host if unset):
# https://YOUR_DOMAIN/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=

# --- Server ---
# PORT=8080
# NODE_ENV=production
# WEB_DIST=/app/web   # path to compiled React app (auto-detected)
