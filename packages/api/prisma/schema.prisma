generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  name                String
  createdAt           DateTime             @default(now())
  flights             Flight[]
  trips               Trip[]
  pushSubscriptions   PushSubscription[]
  calendarConnections CalendarConnection[]
}

model Trip {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  flights   Flight[]
  shareTokens ShareToken[]
}

model Flight {
  id                 String        @id @default(cuid())
  userId             String
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tripId             String?
  trip               Trip?         @relation(fields: [tripId], references: [id], onDelete: SetNull)
  ident              String
  faFlightId         String?
  airlineIata        String?
  flightNumber       String?
  origin             String
  destination        String
  departureScheduled DateTime
  departureEstimated DateTime?
  departureActual    DateTime?
  arrivalScheduled   DateTime
  arrivalEstimated   DateTime?
  arrivalActual      DateTime?
  status             String        @default("scheduled")
  gateDeparture      String?
  gateArrival        String?
  terminalDeparture  String?
  terminalArrival    String?
  baggageClaim       String?
  aircraftType       String?
  registration       String?
  lastPolledAt       DateTime?
  createdAt          DateTime      @default(now())
  events             FlightEvent[]
  shareTokens        ShareToken[]
}

model FlightEvent {
  id         String   @id @default(cuid())
  flightId   String
  flight     Flight   @relation(fields: [flightId], references: [id], onDelete: Cascade)
  eventType  String
  oldValue   String?
  newValue   String?
  occurredAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model ShareToken {
  id        String    @id @default(cuid())
  flightId  String?
  flight    Flight?   @relation(fields: [flightId], references: [id], onDelete: Cascade)
  tripId    String?
  trip      Trip?     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  token     String    @unique
  createdAt DateTime  @default(now())
  revokedAt DateTime?
}

model CalendarConnection {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String
  accessToken  String
  refreshToken String
  syncToken    String?
  channelId    String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
}
