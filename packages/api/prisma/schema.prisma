generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  name                String
  isAdmin             Boolean              @default(false)
  createdAt           DateTime             @default(now())
  flights             Flight[]
  trains              Train[]
  trips               Trip[]
  pushSubscriptions   PushSubscription[]
  calendarConnections CalendarConnection[]
}

model Trip {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  flights   Flight[]
  trains    Train[]
  shareTokens ShareToken[]
}

model Flight {
  id                 String        @id @default(cuid())
  userId             String
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tripId             String?
  trip               Trip?         @relation(fields: [tripId], references: [id], onDelete: SetNull)
  ident              String
  faFlightId         String?
  airlineIata        String?
  flightNumber       String?
  origin             String
  destination        String
  departureScheduled DateTime
  departureEstimated DateTime?
  departureActual    DateTime?
  arrivalScheduled   DateTime
  arrivalEstimated   DateTime?
  arrivalActual      DateTime?
  status             String        @default("scheduled")
  gateDeparture      String?
  gateArrival        String?
  terminalDeparture  String?
  terminalArrival    String?
  baggageClaim       String?
  aircraftType       String?
  registration       String?
  takeoffScheduled   DateTime?
  takeoffEstimated   DateTime?
  takeoffActual      DateTime?
  landingScheduled   DateTime?
  landingEstimated   DateTime?
  landingActual      DateTime?
  seat               String?
  confirmationCode   String?
  calendarEventId    String?       // Google Calendar event.id for dedup
  lastPolledAt       DateTime?
  createdAt          DateTime      @default(now())
  events             FlightEvent[]
  shareTokens        ShareToken[]

  @@unique([userId, calendarEventId])
}

model FlightEvent {
  id         String   @id @default(cuid())
  flightId   String
  flight     Flight   @relation(fields: [flightId], references: [id], onDelete: Cascade)
  eventType  String
  oldValue   String?
  newValue   String?
  occurredAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model ShareToken {
  id        String    @id @default(cuid())
  flightId  String?
  flight    Flight?   @relation(fields: [flightId], references: [id], onDelete: Cascade)
  tripId    String?
  trip      Trip?     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  trainId   String?
  train     Train?    @relation(fields: [trainId], references: [id], onDelete: Cascade)
  token     String    @unique
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  sharePushSubscriptions SharePushSubscription[]
}

model SharePushSubscription {
  id           String     @id @default(cuid())
  shareTokenId String
  shareToken   ShareToken @relation(fields: [shareTokenId], references: [id], onDelete: Cascade)
  endpoint     String     @unique
  p256dh       String
  auth         String
  createdAt    DateTime   @default(now())
}

model CalendarConnection {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String
  accessToken  String
  refreshToken String
  syncToken    String?
  channelId    String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Train {
  id                  String        @id @default(cuid())
  userId              String
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tripId              String?
  trip                Trip?         @relation(fields: [tripId], references: [id], onDelete: SetNull)
  trainNumber         String
  trainName           String?
  origin              String
  destination         String
  originName          String?
  destinationName     String?
  departureScheduled  DateTime
  departureEstimated  DateTime?
  departureActual     DateTime?
  arrivalScheduled    DateTime
  arrivalEstimated    DateTime?
  arrivalActual       DateTime?
  status              String        @default("scheduled")
  stopsJson           String?
  seat                String?
  confirmationCode    String?
  calendarEventId     String?
  lastPolledAt        DateTime?
  createdAt           DateTime      @default(now())
  events              TrainEvent[]
  shareTokens         ShareToken[]

  @@unique([userId, calendarEventId])
}

model TrainEvent {
  id         String   @id @default(cuid())
  trainId    String
  train      Train    @relation(fields: [trainId], references: [id], onDelete: Cascade)
  eventType  String
  oldValue   String?
  newValue   String?
  occurredAt DateTime @default(now())
}
